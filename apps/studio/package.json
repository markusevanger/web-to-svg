{
  "name": "@web-to-svg/studio",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "sanity"
  ],
  "description": "Sanity Studio for webtosvg.com",
  "author": "markusevanger",
  "license": "MIT",
  "main": "package.json",
  "scripts": {
    "build": "sanity build",
    "deploy": "sanity deploy",
    "predev": "pnpm sanity:typegen",
    "dev": "sanity dev",
    "sanity:typegen": "sanity schema extract --enforce-required-fields --path ../../sanity.schema.json && sanity typegen generate",
    "start": "sanity start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sanity/assist": "^5.0.2",
    "@sanity/icons": "^3.7.4",
    "@sanity/vision": "^5.13.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "rxjs": "^7.8.2",
    "sanity": "^5.13.0",
    "sanity-plugin-asset-source-unsplash": "^7.0.0",
    "sanity-plugin-media": "^4.1.1",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^5.0.2",
    "@types/react": "^19.2.7",
    "typescript": "^5.9.3"
  }
}
